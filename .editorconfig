# .editorconfig — https://editorconfig.org
# Keeps indentation, encoding, and line endings consistent across editors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{js,mjs,html,css,json,webmanifest}]
indent_size = 2

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
# Markdown sometimes uses two trailing spaces for a hard line break.
trim_trailing_whitespace = false

[*.sh]
indent_size = 4
